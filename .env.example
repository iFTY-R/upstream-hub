# Postgres（docker-compose 同时用作 backend 的 DB 连接参数）
POSTGRES_USER=upstreamhub
POSTGRES_PASSWORD=change-me
POSTGRES_DB=upstreamhub
# 宿主机映射端口；容器内仍是 5432
POSTGRES_PORT=54329

# 前端对外端口（容器内 backend 仍是 8418，nginx 已下线，前端直接由 Go 嵌入 serve）
UPSTREAMHUB_HTTP_PORT=8080

# Backend 运行模式 / 日志等级（compose 已把数据库参数写死指向 postgres 容器，
# 想本地直跑 go run 时再用 UPSTREAMHUB_DATABASE_HOST 等覆盖）
UPSTREAMHUB_SERVER_MODE=release
UPSTREAMHUB_LOG_LEVEL=info

# 主密钥（任意长度，至少 32 字节随机串），用于 AES-GCM 加密敏感字段。
# **必填** — 修改后既有数据无法解密，请务必妥善保存。
APP_SECRET=please-change-me-to-a-long-random-secret-32bytes-min

# 鉴权开关。默认 true = 访问需要登录。
# 默认账号 admin / admin，首次登录会强制要求修改密码（凭据存数据库，bcrypt 哈希）。
# 纯内网 / 反代后面想免登录可设 AUTH_ENABLED=false。
AUTH_ENABLED=true

# Seed 用的默认管理员账号 / 密码（仅在 admin_users 表为空时生效）。
# ADMIN_PASSWORD 留空 → 播种 admin/admin 且首登强制改密（推荐，最省事）。
# ADMIN_PASSWORD 填了强密码 → 用它播种，无需首登改密。
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# token 签名密钥；留空时回退使用 APP_SECRET
AUTH_TOKEN_SECRET=
